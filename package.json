{
  "name": "aisentica-persistent-self",
  "version": "0.1.0",
  "private": true,
  "description": "Conflict-aware, provenance-preserving persistent memory for agent identity.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "esbuild backend/src/handler.ts --bundle --platform=node --target=node22 --format=esm --outfile=backend/dist/handler.mjs --sourcemap",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm test && npm run build",
    "migrate": "node scripts/migrate.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.850.0",
    "@aws-sdk/client-s3": "^3.850.0",
    "pg": "^8.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.150",
    "@types/node": "^22.15.30",
    "@types/pg": "^8.15.4",
    "esbuild": "^0.25.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
